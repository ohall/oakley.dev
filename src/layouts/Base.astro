---
import BaseHead from "@/components/BaseHead.astro";
import SkipLink from "@/components/SkipLink.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import { siteConfig } from "@/site-config";
import type { SiteMeta } from "@/types";
import "../styles/global.css";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
	</head>
	<body class="min-h-screen">
		<SkipLink />
		
		<div class="max-w-6xl mx-auto px-6 py-12 md:py-20 lg:py-24">
			<div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-12 lg:gap-20">
				<!-- Sidebar -->
				<aside class="lg:sticky lg:top-12 lg:self-start space-y-8">
					<Header />
				</aside>
				
				<!-- Main Content -->
				<main id="main" class="min-w-0">
					<slot />
					<Footer />
				</main>
			</div>
		</div>
	</body>
</html>