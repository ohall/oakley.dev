---
const socialLinks: {
	friendlyName: string;
	link: string;
}[] = [
	{
		friendlyName: "GitHub",
		link: "https://github.com/ohall",
	},
	{
		friendlyName: "LinkedIn",
		link: "https://www.linkedin.com/in/oakleyhall/",
	},
	{
		friendlyName: "Twitter",
		link: "https://twitter.com/_ohall",
	},
	{
		friendlyName: "Medium",
		link: "https://medium.com/@oakley349",
	},
];
---

<nav aria-label="Social links" class="pt-2">
	<ul class="space-y-2">
		{socialLinks.map(({ friendlyName, link }) => (
			<li>
				<a 
					href={link}
					target="_blank"
					rel="noreferrer"
					class="social-link group"
				>
					<span class="text-text-subtle group-hover:text-accent transition-colors">→</span>
					<span>{friendlyName}</span>
				</a>
			</li>
		))}
	</ul>
</nav>