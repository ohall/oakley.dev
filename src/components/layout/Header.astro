---
import SocialList from "@/components/SocialList.astro";
---

<header class="space-y-6">
	<!-- Name Block -->
	<div class="space-y-0">
		<h1 class="font-display text-5xl md:text-6xl font-bold tracking-tight leading-none">
			<span class="block">Oakley</span>
			<span class="block text-text-muted">Hall</span>
		</h1>\t	
		<div class="h-px w-16 bg-accent mt-6 mb-4"></div>
	</div>
	
	<!-- Bio -->
	<p class="text-base leading-relaxed text-text-muted max-w-xs">
		Software engineering lead and architect for Sam's Club and Walmart Global Tech. 
		Building tools that help people work better and smarter.
	</p>
	
	<!-- Social Links -->
	<SocialList />
</header>