---
import { Image } from "astro:assets";
import PageLayout from "@/layouts/Base.astro";
import leaddev2024 from "@/assets/leaddev2024.jpeg";
import leaddev2025 from "@/assets/leaddev2025.jpeg";

// Define interface for Medium post data
interface MediumPost {
	link: string;
	title: string;
	pubDate: string;
}

// Optimize API call with timeout and error handling
let mediumPosts: MediumPost[] = [];
try {
	const controller = new AbortController();
	const timeoutId = setTimeout(() => controller.abort(), 3000);

	const response = await fetch(
		"https://api.rss2json.com/v1/api.json?rss_url=https://medium.com/feed/@oakley349",
		{ signal: controller.signal },
	);
	clearTimeout(timeoutId);

	if (response.ok) {
		const data = await response.json();
		mediumPosts = data.items?.slice(0, 12) || [];
	}
} catch (error) {
	console.log("Failed to fetch Medium posts");
	mediumPosts = [];
}

// Format date function
function formatDate(dateStr: string): string {
	const date = new Date(dateStr);
	return `${date.getMonth() + 1}/${date.getDate()}/${date.getFullYear()}`;
}
---

<PageLayout meta={{ title: "Home" }}>
	<!-- Posts Section -->
	<section aria-label="Blog posts" class="mb-20">
		<h2 class="section-title">Writing</h2>
		<ul class="space-y-4">
			{
				mediumPosts.map((p) => (
					<li class="post-item">
						<time class="post-date" datetime={p.pubDate}>
							{formatDate(p.pubDate)}
						</time>
						<a 
							href={p.link} 
							target="_blank"
							rel="noreferrer"
							class="post-title line-clamp-2"
						>
							{p.title}
						</a>
					</li>
				))
			}
		</ul>
	</section>

	<!-- Live Events Section -->
	<section aria-label="Speaking" class="mb-16" id="live">
		<h2 class="section-title">Speaking</h2>
		
		<div class="space-y-10">
			<!-- LeadDev 2025 -->
			<article class="group">
				<div class="overflow-hidden rounded-sm mb-4">
					<Image
						src={leaddev2025}
						alt="Oakley Hall co-hosting a session at LeadDev New York 2025"
						class="w-full aspect-video object-cover transition-transform duration-500 ease-out-quart group-hover:scale-[1.02]"
						widths={[400, 800, 1200]}
						sizes="(max-width: 768px) 100vw, 600px"
						loading="lazy"
					/>
				</div>
				<h3 class="font-display text-lg font-medium mb-2 leading-tight">
					Co-host of Table Talk session on embedding observability in engineering culture
				</h3>
				<a
					href="https://lnkd.in/ez-wapXr"
					class="text-sm text-text-muted hover:text-accent transition-colors"
					target="_blank"
					rel="noopener noreferrer"
				>
					View LeadDev New York 2025 session details →
				</a>
			</article>
			
			<!-- LeadDev 2024 -->
			<article class="group">
				<div class="overflow-hidden rounded-sm mb-4">
					<Image
						src={leaddev2024}
						alt="Oakley Hall hosting a session at LeadDev New York 2024"
						class="w-full aspect-video object-cover transition-transform duration-500 ease-out-quart group-hover:scale-[1.02]"
						widths={[400, 800, 1200]}
						sizes="(max-width: 768px) 100vw, 600px"
						loading="lazy"
					/>
				</div>
				<h3 class="font-display text-lg font-medium mb-2 leading-tight">
					Host of Next Steps AMA Session on Preparing for the Role of Principal Engineer
				</h3>
				<a
					href="https://lnkd.in/ez-wapXr"
					class="text-sm text-text-muted hover:text-accent transition-colors"
					target="_blank"
					rel="noopener noreferrer"
				>
					View LeadDev New York 2024 AMA details →
				</a>
			</article>
		</div>
	</section>
</PageLayout>